//@version=6
strategy("PA Master Framework", shorttitle="PAMF", overlay=true, pyramiding=0, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.02, calc_on_order_fills=true, calc_on_every_tick=true, process_orders_on_close=true, max_boxes_count=500, max_labels_count=500, max_lines_count=500)

//=============================================================================
// PA MASTER FRAMEWORK
// Version : 0.1.0
// Commit  : 1
//=============================================================================

//-----------------------------------------------------------------------------
// INPUT GROUPS
//-----------------------------------------------------------------------------

groupGeneral = "General"
groupDashboard = "Dashboard"
groupDebug = "Debug"
groupSwing = "Swing Engine"
groupAtr = "ATR Engine"

//-----------------------------------------------------------------------------
// INPUTS
//-----------------------------------------------------------------------------

showDashboard = input.bool(true, "Show Dashboard", group=groupDashboard)
debugMode = input.bool(false, "Debug Mode", group=groupDebug)

atrLength = input.int(14, "ATR Length", minval=1, group=groupAtr)
atrSmooth = input.string("RMA", "ATR Smoothing", options=["RMA", "SMA", "EMA", "WMA"], group=groupAtr)

swingLength = input.int(5, "Swing Length", minval=2, maxval=20, group=groupSwing)
showSwings = input.bool(true, "Show Swing Labels", group=groupSwing)

//-----------------------------------------------------------------------------
// CONSTANTS
//-----------------------------------------------------------------------------

TREND_BULL = 1
TREND_BEAR = -1
TREND_RANGE = 0

BOS_NONE = 0
BOS_BULL = 1
BOS_BEAR = -1

//-----------------------------------------------------------------------------
// STATE
//-----------------------------------------------------------------------------

var int trendState = TREND_RANGE
var table dash = na
var float paSwingHigh = na
var float paSwingLow = na

var int paSwingHighBar = na
var int paSwingLowBar = na

var bool paNewSwingHigh = false
var bool paNewSwingLow = false

var float paPrevSwingHigh = na
var float paPrevSwingLow = na

var bool paHH = false
var bool paLH = false
var bool paHL = false
var bool paLL = false

var bool paBullBos = false
var bool paBearBos = false

var bool paBullChoch = false
var bool paBearChoch = false

var float paLastHH = na
var float paLastLL = na

var int paMarketTrend = TREND_RANGE


///-----------------------------------------------------------------------------
// CANDLE ENGINE
//-----------------------------------------------------------------------------

paOpen = open
paHigh = high
paLow = low
paClose = close

paBody = math.abs(paClose - paOpen)
paRange = paHigh - paLow

paUpperWick = paHigh - math.max(paOpen, paClose)
paLowerWick = math.min(paOpen, paClose) - paLow

paBullish = paClose > paOpen
paBearish = paClose < paOpen
paDoji = paRange > 0 ? paBody <= paRange * 0.10 : false

paBullBody = paBullish ? paBody : 0.0
paBearBody = paBearish ? paBody : 0.0

paBullPower = paRange > 0 ? paBullBody / paRange : 0.0
paBearPower = paRange > 0 ? paBearBody / paRange : 0.0

paMid = (paHigh + paLow) * 0.5
paTypical = (paHigh + paLow + paClose) / 3.0

//-----------------------------------------------------------------------------
// ATR ENGINE
//-----------------------------------------------------------------------------

trueRange = ta.tr(true)

paAtr = atrSmooth == "SMA" ? ta.sma(trueRange, atrLength) : atrSmooth == "EMA" ? ta.ema(trueRange, atrLength) : atrSmooth == "WMA" ? ta.wma(trueRange, atrLength) : ta.rma(trueRange, atrLength)

paHalfAtr = paAtr * 0.50
paQuarterAtr = paAtr * 0.25
paDoubleAtr = paAtr * 2.0

paLargeBody = paBody >= paAtr
paImpulseBull = paBullish and paBody >= paHalfAtr
paImpulseBear = paBearish and paBody >= paHalfAtr

//-----------------------------------------------------------------------------
// SWING ENGINE
//-----------------------------------------------------------------------------

paBullBos := false
paBearBos := false

paBullChoch := false
paBearChoch := false

paHH := false
paLH := false
paHL := false
paLL := false

ph = ta.pivothigh(high, swingLength, swingLength)
pl = ta.pivotlow(low, swingLength, swingLength)

paNewSwingHigh := not na(ph)
paNewSwingLow := not na(pl)

if paNewSwingHigh

    if not na(paPrevSwingHigh)
        paHH := ph > paPrevSwingHigh
        paLH := ph < paPrevSwingHigh

    paPrevSwingHigh := ph
    paSwingHigh := ph
    paSwingHighBar := bar_index - swingLength

    if paHH

        if na(paLastHH)
            paLastHH := ph
        else
            paLastHH := math.max(paLastHH, ph)

if paNewSwingLow

    if not na(paPrevSwingLow)
        paHL := pl > paPrevSwingLow
        paLL := pl < paPrevSwingLow

    paPrevSwingLow := pl
    paSwingLow := pl
    paSwingLowBar := bar_index - swingLength

    if paLL

        if na(paLastLL)
            paLastLL := pl
        else
            paLastLL := math.min(paLastLL, pl)

//-----------------------------------------------------------------------------
// BOS ENGINE
//-----------------------------------------------------------------------------

if not na(paLastHH) and ta.crossover(close, paLastHH)

    paBullBos := true

    if paMarketTrend == TREND_BEAR
        paBullChoch := true

    paMarketTrend := TREND_BULL

if not na(paLastLL) and ta.crossunder(close, paLastLL)

    paBearBos := true

    if paMarketTrend == TREND_BULL
        paBearChoch := true

    paMarketTrend := TREND_BEAR

//-----------------------------------------------------------------------------
// DASHBOARD
//-----------------------------------------------------------------------------

if showDashboard

    if na(dash)
        dash := table.new(position.top_right, 2, 10)

    trendText = paMarketTrend == TREND_BULL ? "Bull" : paMarketTrend == TREND_BEAR ? "Bear" : "Range"

    if trendState == TREND_BULL
        trendText := "Bull"

    if trendState == TREND_BEAR
        trendText := "Bear"

    if barstate.islastconfirmedhistory or barstate.isrealtime

        table.cell(dash, 0, 0, "PA Master")
        table.cell(dash, 1, 0, "v0.1.0")

        table.cell(dash, 0, 1, "Trend")
        table.cell(dash, 1, 1, trendText)

        table.cell(dash, 0, 2, "Bull")
        table.cell(dash, 1, 2, paBullish ? "Yes" : "No")

        table.cell(dash, 0, 3, "Bear")
        table.cell(dash, 1, 3, paBearish ? "Yes" : "No")

        table.cell(dash, 0, 4, "Body")
        table.cell(dash, 1, 4, str.tostring(paBody))

        table.cell(dash, 0, 5, "Range")
        table.cell(dash, 1, 5, str.tostring(paRange))

        table.cell(dash, 0, 6, "Doji")
        table.cell(dash, 1, 6, paDoji ? "Yes" : "No")

        table.cell(dash, 0, 7, "ATR")
        table.cell(dash, 1, 7, str.tostring(paAtr))

        table.cell(dash, 0, 8, "Impulse")
        table.cell(dash, 1, 8, paImpulseBull ? "Bull" : paImpulseBear ? "Bear" : "No")

        table.cell(dash, 0, 9, "Large Body")
        table.cell(dash, 1, 9, paLargeBody ? "Yes" : "No")

//-----------------------------------------------------------------------------
// DEBUG PLOTS
//-----------------------------------------------------------------------------

bodyPlot = debugMode ? paBody : na
rangePlot = debugMode ? paRange : na
bullPowerPlot = debugMode ? paBullPower : na
bearPowerPlot = debugMode ? paBearPower : na


plot(debugMode ? paBody : na, "Body")
plot(debugMode ? paRange : na, "Range")
plot(debugMode ? paAtr : na, "ATR")
plot(debugMode ? paHalfAtr : na, "Half ATR")

plotshape(showSwings and paHH, title="HH", style=shape.triangledown, location=location.abovebar, offset=-swingLength, color=color.lime, size=size.tiny, text="HH")
plotshape(showSwings and paLH, title="LH", style=shape.triangledown, location=location.abovebar, offset=-swingLength, color=color.red, size=size.tiny, text="LH")
plotshape(showSwings and paHL, title="HL", style=shape.triangleup, location=location.belowbar, offset=-swingLength, color=color.lime, size=size.tiny, text="HL")
plotshape(showSwings and paLL, title="LL", style=shape.triangleup, location=location.belowbar, offset=-swingLength, color=color.red, size=size.tiny, text="LL")

plotshape(paBullBos, title="Bull BOS", style=shape.labelup, location=location.belowbar, color=color.green, text="BOS")
plotshape(paBearBos, title="Bear BOS", style=shape.labeldown, location=location.abovebar, color=color.red, text="BOS")
plotshape(paBullChoch, title="Bull CHoCH", style=shape.circle, location=location.belowbar, color=color.blue, size=size.tiny)
plotshape(paBearChoch, title="Bear CHoCH", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny)

plot(paLastHH, "Bull Structure", color=color.green, linewidth=2, style=plot.style_stepline)
plot(paLastLL, "Bear Structure", color=color.red, linewidth=2, style=plot.style_stepline)