//@version=6
strategy("PA Master Framework v2", shorttitle="PAMF v2", overlay=true, pyramiding=0, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.02, calc_on_order_fills=true, calc_on_every_tick=true, process_orders_on_close=true, max_boxes_count=500, max_labels_count=500, max_lines_count=500)

//=============================================================================
// PA MASTER FRAMEWORK V2
// Version : 0.2.0
// Enhanced: Confluence filters, FVG, Liquidity, Volume, Multi-timeframe
//=============================================================================

//-----------------------------------------------------------------------------
// INPUT GROUPS
//-----------------------------------------------------------------------------
groupGeneral = "General"
groupDashboard = "Dashboard"
groupDebug = "Debug"
groupSwing = "Swing Engine"
groupAtr = "ATR Engine"
groupEntry = "Entry Engine"
groupOB = "Order Block"
groupBos = "BOS Engine"
groupStrategy = "Strategy"
groupDisplacement = "Displacement Engine"
groupMarket = "Market State"
groupFilters = "Confluence Filters"
groupFVG = "Fair Value Gap"
groupLiquidity = "Liquidity Zones"
groupVolume = "Volume Filter"
groupTimeframe = "Multi-Timeframe"

//-----------------------------------------------------------------------------
// INPUTS - GENERAL & TIMEFRAME
//-----------------------------------------------------------------------------

showDashboard = input.bool(true, "Show Dashboard", group=groupDashboard)
debugMode = input.bool(false, "Debug Mode", group=groupDebug)

selectedTimeframe = input.string("5", "Current Timeframe", options=["1", "5", "15", "30", "60", "240", "1D"], group=groupTimeframe)
showMTFAnalysis = input.bool(true, "Show MTF Analysis", group=groupTimeframe)

//-----------------------------------------------------------------------------
// INPUTS - ATR
//-----------------------------------------------------------------------------

atrLength = input.int(14, "ATR Length", minval=1, group=groupAtr)
atrSmooth = input.string("RMA", "ATR Smoothing", options=["RMA", "SMA", "EMA", "WMA"], group=groupAtr)

//-----------------------------------------------------------------------------
// INPUTS - SWING & STRUCTURE
//-----------------------------------------------------------------------------

swingLength = input.int(15, "Swing Length", minval=2, maxval=20, group=groupSwing)
showSwings = input.bool(true, "Show Swing Labels", group=groupSwing)


//-----------------------------------------------------------------------------
// INPUTS - BOS ENGINE
//-----------------------------------------------------------------------------

bosBreakMethod = input.string("Close", "Break Confirmation", options=["Close", "Wick"], group=groupBos)
bosAtrFilter = input.bool(true, "Require ATR Impulse", group=groupBos)
requireHigherLowInUptrend = input.bool(true, "HL in Uptrend", group=groupBos)
requireLowerHighInDowntrend = input.bool(true, "LH in Downtrend", group=groupBos)

//-----------------------------------------------------------------------------
// INPUTS - STRATEGY
//-----------------------------------------------------------------------------

enableStrategy = input.bool(true, "Enable Strategy", group=groupStrategy)
slAtrMultiplier = input.float(1.0, "Stop Loss ATR", minval=0.25, step=0.25, group=groupStrategy)
tpAtrMultiplier = input.float(2.0, "Take Profit ATR", minval=0.5, step=0.25, group=groupStrategy)
minRiskReward = input.float(1.5, "Min Risk:Reward Ratio", minval=0.5, step=0.1, group=groupStrategy)

enableLong = input.bool(true, "Enable Long", group=groupEntry)
enableShort = input.bool(true, "Enable Short", group=groupEntry)

useImpulseFilter = input.bool(true, "Require Impulse Candle", group=groupEntry)

//-----------------------------------------------------------------------------
// INPUTS - ORDER BLOCKS
//-----------------------------------------------------------------------------

showOrderBlocks = input.bool(true, "Show Order Blocks", group=groupOB)
maxOrderBlocks = input.int(20, "Maximum Blocks", minval=5, maxval=100, group=groupOB)
obMitigationBuffer = input.float(0.5, "Mitigation Buffer %", minval=0.0, step=0.1, group=groupOB)

//-----------------------------------------------------------------------------
// INPUTS - DISPLACEMENT
//-----------------------------------------------------------------------------

displacementATR = input.float(1.2, "Minimum Body ATR", step=0.1, group=groupDisplacement)
requireCloseNearHigh = input.bool(true, "Bull Close Near High", group=groupDisplacement)
requireCloseNearLow = input.bool(true, "Bear Close Near Low", group=groupDisplacement)

//-----------------------------------------------------------------------------
// INPUTS - MARKET STATE
//-----------------------------------------------------------------------------

showMarketState = input.bool(true, "Show Market State", group=groupMarket)
pullbackAtr = input.float(1.0, "Pullback ATR", step=0.25, group=groupMarket)

//-----------------------------------------------------------------------------
// INPUTS - CONFLUENCE FILTERS
//-----------------------------------------------------------------------------

useConfluenceScore = input.bool(true, "Enable Confluence Scoring", group=groupFilters)
minConfluenceScore = input.int(3, "Min Confluence Score", minval=1, maxval=5, group=groupFilters)
requireTrendAlignment = input.bool(true, "Require Trend Alignment", group=groupFilters)
requireOBMitigation = input.bool(false, "Require OB Mitigation", group=groupFilters)
cooldownBars = input.int(3, "Cooldown Bars After Entry", minval=1, maxval=20, group=groupFilters)

//-----------------------------------------------------------------------------
// INPUTS - FVG (Fair Value Gap)
//-----------------------------------------------------------------------------

detectFVG = input.bool(true, "Detect Fair Value Gaps", group=groupFVG)
showFVG = input.bool(true, "Show FVG Zones", group=groupFVG)
fvgConfirmBars = input.int(2, "FVG Confirmation Bars", minval=1, maxval=5, group=groupFVG)

//-----------------------------------------------------------------------------
// INPUTS - LIQUIDITY
//-----------------------------------------------------------------------------

detectLiquidity = input.bool(true, "Detect Liquidity Zones", group=groupLiquidity)
showLiquidity = input.bool(true, "Show Liquidity Levels", group=groupLiquidity)
liquidityLookback = input.int(20, "Liquidity Lookback", minval=5, maxval=50, group=groupLiquidity)

//-----------------------------------------------------------------------------
// INPUTS - VOLUME
//-----------------------------------------------------------------------------

requireVolumeConfirm = input.bool(true, "Require Volume Confirmation", group=groupVolume)
volumeMultiplier = input.float(1.3, "Volume Confirmation Multiplier", minval=1.0, step=0.1, group=groupVolume)

//-----------------------------------------------------------------------------
// CONSTANTS
//-----------------------------------------------------------------------------
SCRIPT_VERSION = "0.1.0"



//-----------------------------------------------------------------------------
// MARKET STATES
//-----------------------------------------------------------------------------

MARKET_RANGE = 0

MARKET_BULL = 1
MARKET_BULL_PULLBACK = 2

MARKET_BEAR = -1
MARKET_BEAR_PULLBACK = -2

//-----------------------------------------------------------------------------
// STATE
//-----------------------------------------------------------------------------
var table dash = na
var float paSwingHigh = na
var float paSwingLow = na

var int paSwingHighBar = na
var int paSwingLowBar = na

var bool paNewSwingHigh = false
var bool paNewSwingLow = false

var float paPrevSwingHigh = na
var float paPrevSwingLow = na

var bool paHH = false
var bool paLH = false
var bool paHL = false
var bool paLL = false

var bool paBullBos = false
var bool paBearBos = false

var bool paBullChoch = false
var bool paBearChoch = false

var float paLastHH = na
var float paLastLL = na

var bool paLongSignal = false
var bool paShortSignal = false

var string paEntryReason = ""

var string paLastStructure = "None"

//-----------------------------------------------------------------------------
// STRUCTURE STATE
//-----------------------------------------------------------------------------
var float paMarketState = MARKET_RANGE
var float paProtectedLow = na

var int paMarketStateBar = na
var int paProtectedLowBar = na

///-----------------------------------------------------------------------------
// CANDLE ENGINE
//-----------------------------------------------------------------------------
paOpen = open
paHigh = high
paLow = low
paClose = close

paBody = math.abs(paClose - paOpen)
paRange = paHigh - paLow

paUpperWick = paHigh - math.max(paOpen, paClose)
paLowerWick = math.min(paOpen, paClose) - paLow

paBullish = paClose > paOpen
paBearish = paClose < paOpen
paDoji = paRange > 0 ? paBody <= paRange * 0.10 : false

paBullBody = paBullish ? paBody : 0.0
paBearBody = paBearish ? paBody : 0.0

paBullPower = paRange > 0 ? paBullBody / paRange : 0.0
paBearPower = paRange > 0 ? paBearBody / paRange : 0.0

paMid = (paHigh + paLow) * 0.5
paTypical = (paHigh + paLow + paClose) / 3.0

//-----------------------------------------------------------------------------
// ATR ENGINE
//-----------------------------------------------------------------------------
trueRange = ta.tr(true)

paAtr = atrSmooth == "SMA" ? ta.sma(trueRange, atrLength) : atrSmooth == "EMA" ? ta.ema(trueRange, atrLength) : atrSmooth == "WMA" ? ta.wma(trueRange, atrLength) : ta.rma(trueRange, atrLength)

paHalfAtr = paAtr * 0.50
paQuarterAtr = paAtr * 0.25
paDoubleAtr = paAtr * 2.0

paLargeBody = paBody >= paAtr
paImpulseBull = paBullish and paBody >= paHalfAtr
paImpulseBear = paBearish and paBody >= paHalfAtr

//-----------------------------------------------------------------------------
// VOLUME ENGINE
//-----------------------------------------------------------------------------
avgVolume = ta.sma(volume, 20)
volumeConfirm = volume >= avgVolume * volumeMultiplier
lowVolume = volume < avgVolume * 0.7

//-----------------------------------------------------------------------------
// FAIR VALUE GAP ENGINE
//-----------------------------------------------------------------------------
bullFVG = false
bearFVG = false
bullFVGTop = 0.0
bullFVGBottom = 0.0
bearFVGTop = 0.0
bearFVGBottom = 0.0

if detectFVG
    // Bull FVG: High of candle 2 < Low of candle 0
    if high[2] < low[0] and paBullish and paBullish[1]
        bullFVG := true
        bullFVGBottom := high[2]
        bullFVGTop := low[0]

    // Bear FVG: Low of candle 2 > High of candle 0
    if low[2] > high[0] and paBearish and paBearish[1]
        bearFVG := true
        bearFVGTop := low[2]
        bearFVGBottom := high[0]

//-----------------------------------------------------------------------------
// LIQUIDITY ZONES ENGINE
//-----------------------------------------------------------------------------
recentHigh = ta.highest(high, liquidityLookback)
recentLow = ta.lowest(low, liquidityLookback)
lastSwingHigh = paSwingHigh
lastSwingLow = paSwingLow

//-----------------------------------------------------------------------------
// PREMIUM/DISCOUNT ZONE ENGINE
//-----------------------------------------------------------------------------
ema20 = ta.ema(close, 20)
inPremiumZone = close > ema20 * 1.02
inDiscountZone = close < ema20 * 0.98

//-----------------------------------------------------------------------------
// 3-BAR PATTERN ENGINE
//-----------------------------------------------------------------------------
// Inside Bar
insideBar = high <= high[1] and low >= low[1]

// Outside Bar
outsideBar = high > high[1] and low < low[1]

// Engulfing
bullEngulf = paBullish and paBearish[1] and high > high[1] and low < low[1]
bearEngulf = paBearish and paBullish[1] and low < low[1] and high > high[1]

// Pin Bar (long wick, small body)
bullPin = paBullish and paLowerWick > paBody * 2 and paUpperWick < paBody * 0.5
bearPin = paBearish and paUpperWick > paBody * 2 and paLowerWick < paBody * 0.5

//-----------------------------------------------------------------------------
// SWING ENGINE
//-----------------------------------------------------------------------------
paBullBos := false
paBearBos := false

paBullChoch := false
paBearChoch := false

paHH := false
paLH := false
paHL := false
paLL := false

ph = ta.pivothigh(high, swingLength, swingLength)
pl = ta.pivotlow(low, swingLength, swingLength)

paNewSwingHigh := not na(ph)
paNewSwingLow := not na(pl)

if paNewSwingHigh

    if not na(paPrevSwingHigh)
        paHH := ph > paPrevSwingHigh
        paLH := ph < paPrevSwingHigh

    paPrevSwingHigh := ph
    paSwingHigh := ph
    paSwingHighBar := bar_index - swingLength

    if paLH and na(paMarketState)
        paMarketState := ph
        paMarketStateBar := bar_index - swingLength

if paNewSwingLow

    if not na(paPrevSwingLow)
        paHL := pl > paPrevSwingLow
        paLL := pl < paPrevSwingLow

    paPrevSwingLow := pl
    paSwingLow := pl
    paSwingLowBar := bar_index - swingLength

    if paHL and na(paProtectedLow)
        paProtectedLow := pl
        paProtectedLowBar := bar_index - swingLength

//-----------------------------------------------------------------------------
// BOS CONDITIONS
//-----------------------------------------------------------------------------
var bool bullBreak = false
var bool bearBreak = false

if not na(paMarketState)
    bullBreak := bosBreakMethod == "Close" ? ta.crossover(close, paMarketState) : high > paMarketState

if not na(paProtectedLow)
    bearBreak := bosBreakMethod == "Close" ? ta.crossunder(close, paProtectedLow) : low < paProtectedLow

bullValid = bosAtrFilter ? bullBreak and paImpulseBull : bullBreak
bearValid = bosAtrFilter ? bearBreak and paImpulseBear : bearBreak

//-----------------------------------------------------------------------------
// DISPLACEMENT ENGINE (MOVED UP FOR SCOPE)
//-----------------------------------------------------------------------------
bullBodyOK = paBody >= paAtr * displacementATR
bullCloseOK = requireCloseNearHigh ? close >= high - paRange * 0.20 : true
paBullDisplacement = paBullish and bullBodyOK and bullCloseOK

bearBodyOK = paBody >= paAtr * displacementATR
bearCloseOK = requireCloseNearLow ? close <= low + paRange * 0.20 : true
paBearDisplacement = paBearish and bearBodyOK and bearCloseOK

//-----------------------------------------------------------------------------
// BOS ENGINE
//-----------------------------------------------------------------------------
if not na(paMarketState)

    if bullValid

        paBullBos := true

        if paMarketState == MARKET_BEAR
            paBullChoch := true

        paMarketState := MARKET_BULL

if not na(paProtectedLow)

    if bearValid

        paBearBos := true

        if paMarketState == MARKET_BULL
            paBearChoch := true

        paMarketState := MARKET_BEAR


//-----------------------------------------------------------------------------
// ORDER BLOCK ENGINE
//-----------------------------------------------------------------------------

showOB = input.bool(true, "Show Order Blocks", group=groupOB)
deleteMitigatedOB = input.bool(true, "Delete Mitigated", group=groupOB)
extendOB = input.int(200, "Extend Bars", minval=20, group=groupOB)

var box bullOB = na
var box bearOB = na

var float bullOBHigh = na
var float bullOBLow = na

var float bearOBHigh = na
var float bearOBLow = na

var int bullOBBar = na
var int bearOBBar = na


if paBullBos

    int obIndex = bar_index - 1

    while obIndex > 5

        if close[bar_index - obIndex] < open[bar_index - obIndex]

            bullOBHigh := high[bar_index - obIndex]
            bullOBLow := low[bar_index - obIndex]
            bullOBBar := obIndex

            break

        obIndex -= 1
if paBullBos

    for i = 1 to 10

        if close[i] < open[i]

            bullOBHigh := high[i]
            bullOBLow := low[i]
            break

if paBearBos

    for i = 1 to 10

        if close[i] > open[i]

            bearOBHigh := high[i]
            bearOBLow := low[i]
            break

if showOB and paBullBos

    if not na(bullOB)
        box.delete(bullOB)

    bullOB := box.new(
         left = bar_index,
         top = bullOBHigh,
         right = bar_index + extendOB,
         bottom = bullOBLow,
         bgcolor = color.new(color.green,85),
         border_color = color.green)

if showOB and paBearBos

    if not na(bearOB)
        box.delete(bearOB)

    bearOB := box.new(
         left = bar_index,
         top = bearOBHigh,
         right = bar_index + extendOB,
         bottom = bearOBLow,
         bgcolor = color.new(color.red,85),
         border_color = color.red)

if not na(bullOB)

    if low <= bullOBHigh and low >= bullOBLow

        if deleteMitigatedOB
            box.delete(bullOB)
            bullOB := na

if not na(bearOB)

    if high >= bearOBLow and high <= bearOBHigh

        if deleteMitigatedOB
            box.delete(bearOB)
            bearOB := na





//-----------------------------------------------------------------------------
// MARKET STATE ENGINE
//-----------------------------------------------------------------------------
if paBullBos
    paMarketState := MARKET_BULL

if paBearBos
    paMarketState := MARKET_BEAR

if paMarketState == MARKET_BULL

    if close < ta.ema(close,20)

        if paAtr > 0

            if (ta.ema(close,20) - close) > paAtr * pullbackAtr

                paMarketState := MARKET_BULL_PULLBACK

if paMarketState == MARKET_BEAR

    if close > ta.ema(close,20)

        if paAtr > 0

            if (close - ta.ema(close,20)) > paAtr * pullbackAtr

                paMarketState := MARKET_BEAR_PULLBACK

if paMarketState == MARKET_BULL_PULLBACK

    if paBullBos

        paMarketState := MARKET_BULL

if paMarketState == MARKET_BEAR_PULLBACK

    if paBearBos

        paMarketState := MARKET_BEAR



//-----------------------------------------------------------------------------
// COOLDOWN ENGINE
//-----------------------------------------------------------------------------
var int lastLongBar = 0
var int lastShortBar = 0
longCooldown = (bar_index - lastLongBar) < cooldownBars
shortCooldown = (bar_index - lastShortBar) < cooldownBars

//-----------------------------------------------------------------------------
// TRADE LEVELS INITIALIZATION
//-----------------------------------------------------------------------------
var float longStop = na
var float longTarget = na
var float shortStop = na
var float shortTarget = na

//-----------------------------------------------------------------------------
// PARTIAL PROFIT & TRAILING STOPS
//-----------------------------------------------------------------------------
var float longFirstTarget = na
var float shortFirstTarget = na
var bool longPartialTaken = false
var bool shortPartialTaken = false

var float longTrailingStop = na
var float shortTrailingStop = na

var int barsInLongTrend = 0
var int barsInShortTrend = 0

var float lastBullBosPrice = na
var float lastBearBosPrice = na

//-----------------------------------------------------------------------------
// PULLBACK DETECTION
//-----------------------------------------------------------------------------
var bool inLongTrend = false
var bool inShortTrend = false
var float trendHighInLong = na
var float trendLowInShort = na

pullbackThreshold = paAtr * 0.5

//-----------------------------------------------------------------------------
// CONFLUENCE SCORING ENGINE
//-----------------------------------------------------------------------------
longConfluence = 0.0
shortConfluence = 0.0

// BOS Signal
if paBullBos
    longConfluence += 1
if paBearBos
    shortConfluence += 1

// Displacement Signal
if paBullDisplacement
    longConfluence += 1
if paBearDisplacement
    shortConfluence += 1

// Impulse Candle
if paImpulseBull
    longConfluence += 1
if paImpulseBear
    shortConfluence += 1

// Volume Confirmation
if volumeConfirm
    longConfluence += requireVolumeConfirm ? 1 : 0
    shortConfluence += requireVolumeConfirm ? 1 : 0

// FVG Confirmation
if bullFVG
    longConfluence += detectFVG ? 1 : 0
if bearFVG
    shortConfluence += detectFVG ? 1 : 0

// Pin Bar Pattern
if bullPin
    longConfluence += 1
if bearPin
    shortConfluence += 1

// Market Trend Alignment
bullTrendAligned = paMarketState == MARKET_BULL or paMarketState == MARKET_BULL_PULLBACK
bearTrendAligned = paMarketState == MARKET_BEAR or paMarketState == MARKET_BEAR_PULLBACK

if bullTrendAligned
    longConfluence += requireTrendAlignment ? 1 : 0
if bearTrendAligned
    shortConfluence += requireTrendAlignment ? 1 : 0

// Order Block Present
bullOBPresent = not na(bullOB)
bearOBPresent = not na(bearOB)

if bullOBPresent
    longConfluence += 0.5
if bearOBPresent
    shortConfluence += 0.5

//-----------------------------------------------------------------------------
// ENTRY ENGINE
//-----------------------------------------------------------------------------
paLongSignal := false
paShortSignal := false
paEntryReason := ""

// Risk/Reward Validation
longRR = strategy.position_size > 0 and not na(longTarget) and not na(longStop) ? ((longTarget - strategy.position_avg_price) / math.abs(strategy.position_avg_price - longStop)) : 0
shortRR = strategy.position_size < 0 and not na(shortTarget) and not na(shortStop) ? ((math.abs(strategy.position_avg_price - shortTarget)) / math.abs(shortStop - strategy.position_avg_price)) : 0

if enableLong and not longCooldown

    bosValid = paBullBos
    impulseValid = useImpulseFilter ? paImpulseBull : true
    trendValid = requireTrendAlignment ? bullTrendAligned : true
    confluenceValid = useConfluenceScore ? longConfluence >= minConfluenceScore : true
    volumeValid = requireVolumeConfirm ? volumeConfirm : true

    if bosValid and impulseValid and trendValid and confluenceValid and volumeValid
        paLongSignal := true
        paEntryReason := "Bull Confluence (" + str.tostring(longConfluence, "#") + ")"
        lastLongBar := bar_index

if enableShort and not shortCooldown

    bosValid = paBearBos
    impulseValid = useImpulseFilter ? paImpulseBear : true
    trendValid = requireTrendAlignment ? bearTrendAligned : true
    confluenceValid = useConfluenceScore ? shortConfluence >= minConfluenceScore : true
    volumeValid = requireVolumeConfirm ? volumeConfirm : true

    if bosValid and impulseValid and trendValid and confluenceValid and volumeValid
        paShortSignal := true
        paEntryReason := "Bear Confluence (" + str.tostring(shortConfluence, "#") + ")"
        lastShortBar := bar_index

//-----------------------------------------------------------------------------
// LAST OPPOSITE CANDLE
//-----------------------------------------------------------------------------
lastBearHigh = ta.valuewhen(paBearish, high, 0)
lastBearLow = ta.valuewhen(paBearish, low, 0)
lastBearBar = ta.valuewhen(paBearish, bar_index, 0)

lastBullHigh = ta.valuewhen(paBullish, high, 0)
lastBullLow = ta.valuewhen(paBullish, low, 0)
lastBullBar = ta.valuewhen(paBullish, bar_index, 0)

//-----------------------------------------------------------------------------
// ORDER BLOCK ENGINE
//-----------------------------------------------------------------------------
if paBullBos

    bullOBHigh := lastBearHigh
    bullOBLow := lastBearLow

    if not na(bullOB)
        box.delete(bullOB)

    bullOB := box.new(
         lastBearBar,
         bullOBHigh,
         bar_index,
         bullOBLow,
         bgcolor=color.new(color.green,85),
         border_color=color.green)

if paBearBos

    bearOBHigh := lastBullHigh
    bearOBLow := lastBullLow

    if not na(bearOB)
        box.delete(bearOB)

    bearOB := box.new(
         lastBullBar,
         bearOBHigh,
         bar_index,
         bearOBLow,
         bgcolor=color.new(color.red,85),
         border_color=color.red)

if not na(bullOB)
    box.set_right(bullOB, bar_index)

if not na(bearOB)
    box.set_right(bearOB, bar_index)

if not na(bullOB)

    if close < bullOBLow

        box.delete(bullOB)

        bullOB := na
if not na(bearOB)

    if close > bearOBHigh

        box.delete(bearOB)

        bearOB := na

//-----------------------------------------------------------------------------
// ORDER BLOCK MITIGATION
//-----------------------------------------------------------------------------

if not na(bullOB)

    if low <= bullOBLow

        box.set_right(bullOB, bar_index)

        bullOB := na

if not na(bearOB)

    if high >= bearOBHigh

        box.set_right(bearOB, bar_index)

        bearOB := na

        
//-----------------------------------------------------------------------------
// STRATEGY CONDITIONS
//-----------------------------------------------------------------------------

longCondition =    enableStrategy and    paLongSignal and    strategy.position_size <= 0
shortCondition =    enableStrategy and    paShortSignal and    strategy.position_size >= 0

//-----------------------------------------------------------------------------
// STRATEGY EXECUTION
//-----------------------------------------------------------------------------

if longCondition
    strategy.entry("Long", strategy.long)

if shortCondition
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    longStop := longTrailingStop
    longTarget := strategy.position_avg_price + paAtr * tpAtrMultiplier

    // Initialize partial profit levels on first bar of trade
    if na(longFirstTarget)
        longFirstTarget := strategy.position_avg_price + paAtr * 1.0
        longTrailingStop := strategy.position_avg_price - paAtr * slAtrMultiplier
        longPartialTaken := false
        inLongTrend := true
        barsInLongTrend := 0
        lastBullBosPrice := strategy.position_avg_price

    // Update trailing stop (lock in profits)
    if high > (lastBullBosPrice + paAtr * 0.5)
        longTrailingStop := math.max(longTrailingStop, high - paAtr * 0.75)

    barsInLongTrend += 1

if strategy.position_size < 0
    shortStop := shortTrailingStop
    shortTarget := strategy.position_avg_price - paAtr * tpAtrMultiplier

    // Initialize partial profit levels on first bar of trade
    if na(shortFirstTarget)
        shortFirstTarget := strategy.position_avg_price - paAtr * 1.0
        shortTrailingStop := strategy.position_avg_price + paAtr * slAtrMultiplier
        shortPartialTaken := false
        inShortTrend := true
        barsInShortTrend := 0
        lastBearBosPrice := strategy.position_avg_price

    // Update trailing stop (lock in profits)
    if low < (lastBearBosPrice - paAtr * 0.5)
        shortTrailingStop := math.min(shortTrailingStop, low + paAtr * 0.75)

    barsInShortTrend += 1

//-----------------------------------------------------------------------------
// PARTIAL PROFIT TAKING & EXITS
//-----------------------------------------------------------------------------

// LONG: Partial profit at first target
if strategy.position_size > 0 and close >= longFirstTarget and not longPartialTaken
    strategy.close("Long", qty=strategy.position_size * 0.5, comment="Partial TP")
    longPartialTaken := true

// SHORT: Partial profit at first target
if strategy.position_size < 0 and close <= shortFirstTarget and not shortPartialTaken
    strategy.close("Short", qty=math.abs(strategy.position_size) * 0.5, comment="Partial TP")
    shortPartialTaken := true

// LONG: Full exit with trailing stop or take profit
strategy.exit("Long Exit", from_entry="Long", stop=longStop, limit=longTarget)

// SHORT: Full exit with trailing stop or take profit
strategy.exit("Short Exit", from_entry="Short", stop=shortStop, limit=shortTarget)

//-----------------------------------------------------------------------------
// PULLBACK RE-ENTRY DETECTION
//-----------------------------------------------------------------------------

// Detect pullback in long trend
pullbackInLong = inLongTrend and barsInLongTrend > 3 and close < lastBullBosPrice and paBearish and paImpulseBear
longPullbackEntry = pullbackInLong and longConfluence >= 2 and paMarketState == MARKET_BULL

// Detect pullback in short trend
pullbackInShort = inShortTrend and barsInShortTrend > 3 and close > lastBearBosPrice and paBullish and paImpulseBull
shortPullbackEntry = pullbackInShort and shortConfluence >= 2 and paMarketState == MARKET_BEAR

//-----------------------------------------------------------------------------
// PULLBACK RE-ENTRIES
//-----------------------------------------------------------------------------

if enableLong and longPullbackEntry and strategy.position_size <= 0 and not longCooldown
    strategy.entry("Long Pullback", strategy.long, comment="Pullback Re-entry")
    inLongTrend := true
    barsInLongTrend := 0
    longPartialTaken := false
    longFirstTarget := close + paAtr * 1.0
    longTrailingStop := close - paAtr * slAtrMultiplier
    lastBullBosPrice := close
    lastLongBar := bar_index

if enableShort and shortPullbackEntry and strategy.position_size >= 0 and not shortCooldown
    strategy.entry("Short Pullback", strategy.short, comment="Pullback Re-entry")
    inShortTrend := true
    barsInShortTrend := 0
    shortPartialTaken := false
    shortFirstTarget := close - paAtr * 1.0
    shortTrailingStop := close + paAtr * slAtrMultiplier
    lastBearBosPrice := close
    lastShortBar := bar_index

//-----------------------------------------------------------------------------
// RESET TREND AFTER EXIT
//-----------------------------------------------------------------------------

if strategy.position_size == 0
    inLongTrend := false
    inShortTrend := false
    barsInLongTrend := 0
    barsInShortTrend := 0
    longFirstTarget := na
    shortFirstTarget := na
    longPartialTaken := false
    shortPartialTaken := false
    longTrailingStop := na
    shortTrailingStop := na

//-----------------------------------------------------------------------------
// DASHBOARD COLORS
//-----------------------------------------------------------------------------

tableHeader = color.rgb(35,35,35)
tableLabel = color.rgb(55,55,55)
tableValue = color.rgb(20,20,20)

tableBull = color.rgb(0,140,60)
tableBear = color.rgb(180,40,40)
tableNeutral = color.rgb(80,80,80)
tableWaiting = color.rgb(180,120,0)

tableText = color.white


//-----------------------------------------------------------------------------
// MULTI-TIMEFRAME ANALYSIS
//-----------------------------------------------------------------------------

mtf1 = request.security(syminfo.tickerid, "5", close)
mtf2 = request.security(syminfo.tickerid, "60", close)
mtf3 = request.security(syminfo.tickerid, "D", close)

mtf1Trend = request.security(syminfo.tickerid, "5", paMarketState)
mtf2Trend = request.security(syminfo.tickerid, "60", paMarketState)
mtf3Trend = request.security(syminfo.tickerid, "D", paMarketState)

//-----------------------------------------------------------------------------
// DASHBOARD
//-----------------------------------------------------------------------------

if showDashboard

    if na(dash)
        dash := table.new(position.top_right, 2, 24)


    stateText =
     paMarketState == MARKET_BULL ? "Bull Trend" :
     paMarketState == MARKET_BULL_PULLBACK ? "Bull Pullback" :
     paMarketState == MARKET_BEAR ? "Bear Trend" :
     paMarketState == MARKET_BEAR_PULLBACK ? "Bear Pullback" :
     "Range"

    stateColor =
     paMarketState == MARKET_BULL ? tableBull :
     paMarketState == MARKET_BULL_PULLBACK ? color.teal :
     paMarketState == MARKET_BEAR ? tableBear :
     paMarketState == MARKET_BEAR_PULLBACK ? color.orange :
     tableNeutral

    structureText = paBullBos ? "Bull BOS" : paBearBos ? "Bear BOS" : "None"
    structureColor = paBullBos ? tableBull : paBearBos ? tableBear : tableNeutral

    entryText = paEntryReason == "" ? "Waiting" : paEntryReason
    entryColor = paEntryReason == "" ? tableWaiting : paBullBos ? tableBull : tableBear

    if barstate.islastconfirmedhistory or barstate.isrealtime

        // Header
        table.cell(dash,0,0,"PA Master v2",bgcolor=tableHeader,text_color=tableText)
        table.cell(dash,1,0,"15m",bgcolor=tableHeader,text_color=tableText)

        // === MARKET STATE ===
        table.cell(dash,0,1,"State",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,1,stateText,bgcolor=stateColor,text_color=tableText)

        // Structure
        table.cell(dash,0,2,"Structure",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,2,structureText,bgcolor=structureColor,text_color=tableText)

        // === SIGNALS & CONFLUENCE ===
        table.cell(dash,0,3,"Entry Signal",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,3,entryText,bgcolor=entryColor,text_color=tableText)

        // Confluence Score
        table.cell(dash,0,4,"Confluence",bgcolor=tableLabel,text_color=tableText)
        confText = paLongSignal ? str.tostring(longConfluence, "#") + "L" : paShortSignal ? str.tostring(shortConfluence, "#") + "S" : "-"
        confColor = (longConfluence >= minConfluenceScore or shortConfluence >= minConfluenceScore) ? color.green : tableNeutral
        table.cell(dash,1,4,confText,bgcolor=confColor,text_color=tableText)

        // === CANDLE ANALYSIS ===
        table.cell(dash,0,5,"Candle",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,5,paBullish ? "Bull" : "Bear",bgcolor=paBullish ? tableBull : tableBear,text_color=tableText)

        // Pattern
        table.cell(dash,0,6,"Pattern",bgcolor=tableLabel,text_color=tableText)
        patternText = bullPin ? "Bull Pin" : bearPin ? "Bear Pin" : bullEngulf ? "Bull Engulf" : bearEngulf ? "Bear Engulf" : insideBar ? "Inside" : outsideBar ? "Outside" : "-"
        table.cell(dash,1,6,patternText,bgcolor=tableValue,text_color=tableText)

        // === VOLATILITY & VOLUME ===
        table.cell(dash,0,7,"ATR",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,7,str.tostring(paAtr,"#.##"),bgcolor=tableValue,text_color=tableText)

        // Volume
        table.cell(dash,0,8,"Volume",bgcolor=tableLabel,text_color=tableText)
        volText = volumeConfirm ? "High" : lowVolume ? "Low" : "Avg"
        volColor = volumeConfirm ? color.green : lowVolume ? color.red : tableNeutral
        table.cell(dash,1,8,volText,bgcolor=volColor,text_color=tableText)

        // === PRICE ACTION ===
        table.cell(dash,0,9,"Impulse",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,9,paImpulseBull ? "Bull" : paImpulseBear ? "Bear" : "No",bgcolor=paImpulseBull ? tableBull : paImpulseBear ? tableBear : tableNeutral,text_color=tableText)

        // Displacement
        table.cell(dash,0,10,"Displacement",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,10,paBullDisplacement ? "Bull" : paBearDisplacement ? "Bear" : "No",bgcolor=paBullDisplacement ? tableBull : paBearDisplacement ? tableBear : tableNeutral,text_color=tableText)

        // FVG
        table.cell(dash,0,11,"FVG",bgcolor=tableLabel,text_color=tableText)
        fvgText = bullFVG ? "Bull" : bearFVG ? "Bear" : "No"
        table.cell(dash,1,11,fvgText,bgcolor=(bullFVG or bearFVG) ? tableBull : tableNeutral,text_color=tableText)

        // Order Block
        table.cell(dash,0,12,"Order Block",bgcolor=tableLabel,text_color=tableText)
        obStatus = not na(bullOB) ? "Bull" : not na(bearOB) ? "Bear" : "None"
        table.cell(dash,1,12,obStatus,bgcolor=not na(bullOB) ? tableBull : not na(bearOB) ? tableBear : tableNeutral,text_color=tableText)

        // === RISK MANAGEMENT ===
        table.cell(dash,0,13,"Stop Loss",bgcolor=tableLabel,text_color=tableText)
        slText = strategy.position_size > 0 ? str.tostring(longStop, "#.##") : strategy.position_size < 0 ? str.tostring(shortStop, "#.##") : "-"
        table.cell(dash,1,13,slText,bgcolor=tableValue,text_color=tableText)

        // Take Profit
        table.cell(dash,0,14,"Take Profit",bgcolor=tableLabel,text_color=tableText)
        tpText = strategy.position_size > 0 ? str.tostring(longTarget, "#.##") : strategy.position_size < 0 ? str.tostring(shortTarget, "#.##") : "-"
        table.cell(dash,1,14,tpText,bgcolor=tableValue,text_color=tableText)

        // R:R Ratio
        table.cell(dash,0,15,"R:R Ratio",bgcolor=tableLabel,text_color=tableText)
        rrText = strategy.position_size > 0 ? str.tostring(longRR, "#.##") : strategy.position_size < 0 ? str.tostring(shortRR, "#.##") : "-"
        table.cell(dash,1,15,rrText,bgcolor=tableValue,text_color=tableText)

        // === POSITION ===
        table.cell(dash,0,16,"Position",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,16,str.tostring(strategy.position_size),bgcolor=tableValue,text_color=tableText)

        // PnL
        table.cell(dash,0,17,"Net PnL",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,17,str.tostring(strategy.netprofit,"#.##"),bgcolor=strategy.netprofit >= 0 ? tableBull : tableBear,text_color=tableText)

        // === TIMEFRAME ===
        table.cell(dash,0,18,"Timeframe",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,18,selectedTimeframe + "m",bgcolor=tableValue,text_color=tableText)

        // Win Rate
        winRate = strategy.wintrades + strategy.losstrades > 0 ? (strategy.wintrades / (strategy.wintrades + strategy.losstrades)) * 100 : 0
        table.cell(dash,0,19,"Win Rate",bgcolor=tableLabel,text_color=tableText)
        table.cell(dash,1,19,str.tostring(winRate, "#.##") + "%",bgcolor=tableValue,text_color=tableText)

        // === ADVANCED FEATURES ===
        // Partial Profit Status
        table.cell(dash,0,20,"Partial TP",bgcolor=tableLabel,text_color=tableText)
        ptpStatus = strategy.position_size > 0 and longPartialTaken ? "✓ Taken" : strategy.position_size < 0 and shortPartialTaken ? "✓ Taken" : strategy.position_size != 0 ? "Pending" : "-"
        ptpColor = (longPartialTaken or shortPartialTaken) ? tableBull : strategy.position_size != 0 ? tableWaiting : tableNeutral
        table.cell(dash,1,20,ptpStatus,bgcolor=ptpColor,text_color=tableText)

        // Trailing Stop Status
        table.cell(dash,0,21,"Trailing SL",bgcolor=tableLabel,text_color=tableText)
        tsStatus = strategy.position_size > 0 ? str.tostring(longTrailingStop, "#.##") : strategy.position_size < 0 ? str.tostring(shortTrailingStop, "#.##") : "-"
        table.cell(dash,1,21,tsStatus,bgcolor=tableValue,text_color=tableText)

        // Trend Status
        table.cell(dash,0,22,"Trend",bgcolor=tableLabel,text_color=tableText)
        trendStatus = inLongTrend ? "Bull (" + str.tostring(barsInLongTrend) + ")" : inShortTrend ? "Bear (" + str.tostring(barsInShortTrend) + ")" : "None"
        trendColor = inLongTrend ? tableBull : inShortTrend ? tableBear : tableNeutral
        table.cell(dash,1,22,trendStatus,bgcolor=trendColor,text_color=tableText)

        // First Target
        table.cell(dash,0,23,"1st Target",bgcolor=tableLabel,text_color=tableText)
        ftText = strategy.position_size > 0 ? str.tostring(longFirstTarget, "#.##") : strategy.position_size < 0 ? str.tostring(shortFirstTarget, "#.##") : "-"
        table.cell(dash,1,23,ftText,bgcolor=tableValue,text_color=tableText)

//-----------------------------------------------------------------------------
// VISUALIZATIONS
//-----------------------------------------------------------------------------

// Swing Highs and Lows
plotshape(showSwings and paNewSwingHigh, title="Swing High", style=shape.triangledown, location=location.abovebar, offset=-swingLength, color=color.blue, size=size.small, text="SH")
plotshape(showSwings and paNewSwingLow, title="Swing Low", style=shape.triangleup, location=location.belowbar, offset=-swingLength, color=color.purple, size=size.small, text="SL")

// Structure Markers
plotshape(showSwings and paHH, title="HH", style=shape.triangledown, location=location.abovebar, offset=-swingLength, color=color.lime, size=size.tiny, text="HH")
plotshape(showSwings and paLH, title="LH", style=shape.triangledown, location=location.abovebar, offset=-swingLength, color=color.red, size=size.tiny, text="LH")
plotshape(showSwings and paHL, title="HL", style=shape.triangleup, location=location.belowbar, offset=-swingLength, color=color.lime, size=size.tiny, text="HL")
plotshape(showSwings and paLL, title="LL", style=shape.triangleup, location=location.belowbar, offset=-swingLength, color=color.red, size=size.tiny, text="LL")

// BOS and CHoCH Markers
plotshape(paBullBos, title="Bull BOS", style=shape.labelup, location=location.belowbar, color=color.green, text="BOS", size=size.small)
plotshape(paBearBos, title="Bear BOS", style=shape.labeldown, location=location.abovebar, color=color.red, text="BOS", size=size.small)
plotshape(paBullChoch, title="Bull CHoCH", style=shape.circle, location=location.belowbar, color=color.blue, size=size.tiny)
plotshape(paBearChoch, title="Bear CHoCH", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny)

// Market Structure Lines
plot(paMarketState, "Protected High", color=color.orange, linewidth=2, style=plot.style_stepline)
plot(paProtectedLow, "Protected Low", color=color.aqua, linewidth=2, style=plot.style_stepline)

// Displacement Markers
plotshape(paBullDisplacement, style=shape.square, color=color.green, size=size.tiny, title="Bull Displacement")
plotshape(paBearDisplacement, style=shape.square, color=color.red, size=size.tiny, title="Bear Displacement")

// FVG Zones
var box bullFVGBox = na
var box bearFVGBox = na

if showFVG and detectFVG
    if bullFVG
        if not na(bullFVGBox)
            box.delete(bullFVGBox)
        bullFVGBox := box.new(bar_index - 1, bullFVGTop, bar_index + 5, bullFVGBottom, bgcolor=color.new(color.green, 90), border_color=na)
    if bearFVG
        if not na(bearFVGBox)
            box.delete(bearFVGBox)
        bearFVGBox := box.new(bar_index - 1, bearFVGTop, bar_index + 5, bearFVGBottom, bgcolor=color.new(color.red, 90), border_color=na)

// Liquidity Zones
plotRecentHigh = (showLiquidity and detectLiquidity) ? recentHigh : na
plotRecentLow = (showLiquidity and detectLiquidity) ? recentLow : na
plot(plotRecentHigh, title="Recent High", color=color.new(color.blue, 50), linewidth=1, style=plot.style_circles)
plot(plotRecentLow, title="Recent Low", color=color.new(color.orange, 50), linewidth=1, style=plot.style_circles)

// 3-Bar Patterns
plotshape(bullPin, style=shape.triangleup, color=color.lime, size=size.small, title="Bull Pin", location=location.belowbar)
plotshape(bearPin, style=shape.triangledown, color=color.red, size=size.small, title="Bear Pin", location=location.abovebar)

// Entry Signals (with Confluence Score)
plotshape(paLongSignal, title="Long Entry", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 20), textcolor=color.white, size=size.large, text="LONG")
plotshape(paShortSignal, title="Short Entry", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 20), textcolor=color.white, size=size.large, text="SHORT")

// Stop Loss and Take Profit
plotLongSL = strategy.position_size > 0 ? longStop : na
plotLongTP = strategy.position_size > 0 ? longTarget : na
plotShortSL = strategy.position_size < 0 ? shortStop : na
plotShortTP = strategy.position_size < 0 ? shortTarget : na

plot(plotLongSL, title="Long Stop Loss", color=color.red, linewidth=2, style=plot.style_linebr)
plot(plotLongTP, title="Long Take Profit", color=color.green, linewidth=2, style=plot.style_linebr)
plot(plotShortSL, title="Short Stop Loss", color=color.red, linewidth=2, style=plot.style_linebr)
plot(plotShortTP, title="Short Take Profit", color=color.green, linewidth=2, style=plot.style_linebr)